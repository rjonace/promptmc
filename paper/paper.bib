% PromptMC — JOSS paper bibliography
%
% RULE: this file is the *bibliography of the paper*, not a reading list.
% An entry belongs here only if it will be CITED in paper.md — i.e. you can
% point to the sentence that needs it. "Useful but not cited" stays in your
% reading list (private/REFERENCE_AND_PRACTICE.md), never here.
%
% Add entries only when you've actually read + verified them, and include a
% DOI/URL (JOSS auto-links DOIs and the review checks they resolve).
%
% Entry types are NOT limited to journal articles. JOSS explicitly wants
% software and datasets cited too:
%   @article       journal articles
%   @misc          software, arXiv preprints, datasets, web docs
%   @inproceedings conference papers
%   @techreport    lab / technical reports (e.g. LA-UR, ICSBEP)
%   @book          textbooks
%   @manual        software manuals / documentation
%
% ---------------------------------------------------------------------------

% --- Core: the thing PromptMC is built on -------------------------------

@article{romano2015openmc,
  author  = {Romano, Paul K. and Horelik, Nicholas E. and Herman, Bryan R.
             and Nelson, Adam G. and Forget, Benoit and Smith, Kord},
  title   = {{OpenMC}: A State-of-the-Art {Monte Carlo} Code for Research
             and Development},
  journal = {Annals of Nuclear Energy},
  volume  = {82},
  pages   = {90--97},
  year    = {2015},
  doi     = {10.1016/j.anucene.2014.07.048}
}

% OpenMC the software (distinct from the paper above). Plain BibTeX has no
% @software type, so @misc is the portable choice; pin the version you tested
% against when you cite it.
@misc{openmc_software,
  author       = {{OpenMC Development Team}},
  title        = {{OpenMC}: A {Monte Carlo} Particle Transport Code},
  howpublished = {\url{https://openmc.org}},
  note         = {Version X.Y.Z; \url{https://github.com/openmc-dev/openmc}},
  year         = {2026}
}

